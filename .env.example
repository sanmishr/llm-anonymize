# llm-anonymize configuration
# Copy this file to .env and fill in your values.
# Env vars take precedence over .env file values.

# --- Ollama (local LLM for anonymization) ---
# ANONYMIZE_MODEL=qwen3:32b
# OLLAMA_URL=http://localhost:11434/api/generate

# --- Cloud LLM API keys (only needed for 'pipeline' command) ---
# DEEPSEEK_API_KEY=sk-...
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AI...
# MINIMAX_API_KEY=...

# --- GDPR/EU AI Act Compliance (optional) ---
# ANONYMIZE_COMPLIANCE=1              # Enable audit logging (default: off)
# COMPLIANCE_DB=~/.llm-anonymize/compliance.db  # SQLite path (default)
# DATABASE_URL=postgresql://user:pass@localhost/mydb  # Use PostgreSQL instead
# COMPLIANCE_RETENTION=90             # Days to keep records (default: 90)
